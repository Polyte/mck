# Contact form — SMTP (any provider: Microsoft 365, Google Workspace, cPanel, SendGrid SMTP, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# Use true for implicit TLS (typical on port 465). For 587, leave unset or false (STARTTLS).
# SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password_or_app_password

# Shown as the sender (must be allowed by your SMTP account / domain)
MAIL_FROM=Mckeywa Projects <info@mckeywa.co.za>

# Inbox(es) for enquiry notifications — comma-separated for multiple
CONTACT_TO_EMAIL=info@mckeywa.co.za

# DeepSeek (Remi chat) — Netlify: Site configuration → Environment variables → AI_CHAT_API_KEY, then redeploy.
# Local / Docker: set in .env (not committed). Do not use placeholder keys in production.
AI_CHAT_API_KEY=your_deepseek_api_key_here

# Google Maps API Key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Server Port (Express server.js)
PORT=3002

# Optional: absolute origin for API calls from the browser (e.g. https://api.example.com). Leave unset for same-origin /api and Netlify functions.
# VITE_API_BASE_URL=https://your-api-host.example.com
